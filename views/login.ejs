<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>E-Shop | Login</title>

    <!-- Font Awesome -->

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{

    height:100vh;

    display:flex;

    justify-content:center;

    align-items:center;

    background:linear-gradient(135deg,#2563eb,#1e3a8a);

}

.login-card{

    width:420px;

    background:rgba(18,24,45,.95);

    padding:45px;

    border-radius:20px;

    color:white;

    box-shadow:0 15px 35px rgba(0,0,0,.35);

}

.logo{

    width:65px;
    height:65px;

    background:#2563eb;

    border-radius:15px;

    display:flex;

    justify-content:center;

    align-items:center;

    margin:auto;

    font-size:28px;

    font-weight:bold;

}

h2{

    margin-top:25px;

    text-align:center;

}

.subtitle{

    text-align:center;

    color:#aaa;

    margin:10px 0 35px;

}

.input-box{

    position:relative;

    margin-bottom:22px;

}

.input-box i{

    position:absolute;

    top:15px;

    left:15px;

    color:#999;

}

.input-box input{

    width:100%;

    padding:15px 45px;

    border:none;

    outline:none;

    border-radius:10px;

    background:#27314f;

    color:white;

    font-size:16px;

}

.toggle{

    position:absolute;

    right:18px;

    top:15px;

    cursor:pointer;

    color:#aaa;

}

.options{

    display:flex;

    justify-content:space-between;

    font-size:14px;

    margin-bottom:25px;

}

.options a{

    color:#4ea3ff;

    text-decoration:none;

}

button{

    width:100%;

    border:none;

    padding:15px;

    background:#2563eb;

    color:white;

    border-radius:10px;

    font-size:17px;

    cursor:pointer;

    transition:.3s;

}

button:hover{

    background:#1d4ed8;

}

.signup{

    margin-top:25px;

    text-align:center;

}

.signup a{

    color:#4ea3ff;

    text-decoration:none;

}

@media(max-width:500px){

.login-card{

width:90%;

padding:30px;

}

}

    </style>

</head>

<body>

<div class="login-card">

<div class="logo">

E

</div>

<h2>Welcome Back</h2>

<p class="subtitle">

Sign in to continue shopping

</p>

<form action="/login" method="POST">

<div class="input-box">

<i class="fa-solid fa-envelope"></i>

<input
type="email"
name="email"
placeholder="Enter your email"
required>

</div>

<div class="input-box">

<i class="fa-solid fa-lock"></i>

<input
type="password"
id="password"
name="password"
placeholder="Enter your password"
required>

<i
class="fa-solid fa-eye toggle"
onclick="togglePassword()"></i>

</div>

<div class="options">

<label>

<input type="checkbox">

 Remember Me

</label>

<a href="#">

Forgot Password?

</a>

</div>

<button>

<i class="fa-solid fa-right-to-bracket"></i>

 Login

</button>

</form>

<div class="signup">

Don't have an account?

<a href="/register">

Register

</a>

</div>

</div>

<script>

function togglePassword(){

let pass=document.getElementById("password");

if(pass.type==="password")

pass.type="text";

else

pass.type="password";

}

</script>

</body>

</html>