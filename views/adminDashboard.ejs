<!DOCTYPE html>

<html>

<head>

<title>Admin Dashboard</title>

<link rel="stylesheet" href="/css/style.css">

</head>

<body>

<h1 style="text-align:center;margin:30px;">

Admin Dashboard

</h1>

<div style="text-align:center;">

<a href="/admin/add">

<button>

➕ Add Product

</button>

</a>

</div>

<br>

<div class="product-grid">

<% products.forEach(product=>{ %>

<div class="card">

<img src="<%= product.image %>">

<h3><%= product.name %></h3>

<h4>₹ <%= product.price %></h4>

<a href="/admin/delete/<%= product._id %>">

<button>

Delete

</button>

</a>

</div>

<% }) %>

</div>

</body>

</html>